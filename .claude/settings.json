{
  "permissions": {
    "deny": [
      "Bash(git push * main)",
      "Bash(git push * main *)",
      "Bash(git push * release/*)",
      "Bash(git push main *)",
      "Bash(git push release/*)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git checkout . *)",
      "Bash(git checkout .)",
      "Bash(git restore . *)",
      "Bash(git restore .)",
      "Bash(git branch -D *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prisma-schema-hook.sh"
          }
        ]
      }
    ]
  }
}
